diff --git a/tlatrace/trace_with_tla.go b/tlatrace/trace_with_tla.go
new file mode 100644
index 0000000..38460ce
--- /dev/null
+++ b/tlatrace/trace_with_tla.go
@@ -0,0 +1,67 @@
+//go:build with_tla
+
+package tlatrace
+
+import (
+	"encoding/json"
+	"os"
+	"path/filepath"
+	"sync"
+	"time"
+)
+
+type envelope struct {
+	TS    string      `json:"ts"`
+	Event interface{} `json:"event"`
+}
+
+var (
+	once  sync.Once
+	mu    sync.Mutex
+	w     *os.File
+	alias = "participant"
+)
+
+func Enabled() bool { return true }
+
+func SetAlias(a string) {
+	if a != "" {
+		alias = a
+	}
+}
+
+func initWriter() {
+	path := os.Getenv("TLA_TRACE_FILE")
+	if path == "" {
+		path = TracePath()
+	}
+	dir := filepath.Dir(path)
+	if dir != "" && dir != "." {
+		_ = os.MkdirAll(dir, 0o755)
+	}
+	f, err := os.OpenFile(path, os.O_CREATE|os.O_TRUNC|os.O_WRONLY, 0o644)
+	if err == nil {
+		w = f
+		return
+	}
+	w = os.Stdout
+}
+
+func TracePath() string {
+	return filepath.Join("traces", alias+".ndjson")
+}
+
+func Emit(event interface{}) {
+	once.Do(initWriter)
+	e := envelope{
+		TS:    time.Now().UTC().Format(time.RFC3339Nano),
+		Event: event,
+	}
+	b, err := json.Marshal(e)
+	if err != nil {
+		return
+	}
+	mu.Lock()
+	defer mu.Unlock()
+	_, _ = w.Write(append(b, '\n'))
+}
-- 
