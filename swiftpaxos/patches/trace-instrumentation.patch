diff --git a/swift/trace_helpers.go b/swift/trace_helpers.go
new file mode 100644
index 0000000..12af618
--- /dev/null
+++ b/swift/trace_helpers.go
@@ -0,0 +1,104 @@
+package swift
+
+import (
+	"fmt"
+	"strconv"
+
+	"github.com/imdea-software/swiftpaxos/state"
+	"github.com/imdea-software/swiftpaxos/tlatrace"
+)
+
+func statusName(status int) string {
+	switch status {
+	case NORMAL:
+		return "NORMAL"
+	case RECOVERING:
+		return "RECOVERING"
+	default:
+		return "UNKNOWN"
+	}
+}
+
+func phaseName(phase int) string {
+	switch phase {
+	case START:
+		return "START"
+	case PRE_ACCEPT:
+		return "PRE_ACCEPT"
+	case ACCEPT:
+		return "ACCEPT"
+	case COMMIT:
+		return "COMMIT"
+	default:
+		return "UNKNOWN"
+	}
+}
+
+func commandIDString(cmdID CommandId) string {
+	return fmt.Sprintf("%d,%d", cmdID.ClientId, cmdID.SeqNum)
+}
+
+func commandIDMap(cmdID CommandId) map[string]interface{} {
+	return map[string]interface{}{
+		"client": cmdID.ClientId,
+		"seq":    cmdID.SeqNum,
+	}
+}
+
+func depToStrings(dep Dep) []string {
+	out := make([]string, 0, len(dep))
+	for _, d := range dep {
+		out = append(out, commandIDString(d))
+	}
+	return out
+}
+
+func commandMap(cmd state.Command) map[string]interface{} {
+	op := "NONE"
+	switch cmd.Op {
+	case state.PUT:
+		op = "PUT"
+	case state.GET:
+		op = "GET"
+	case state.SCAN:
+		op = "SCAN"
+	}
+	return map[string]interface{}{
+		"op":  op,
+		"key": int64(cmd.K),
+	}
+}
+
+func (r *Replica) traceReplicaEvent(name string, extra map[string]interface{}) {
+	event := map[string]interface{}{
+		"name":   name,
+		"module": "swift_replica",
+		"nid":    strconv.FormatInt(int64(r.Id), 10),
+		"state": map[string]interface{}{
+			"ballot":  r.ballot,
+			"cballot": r.cballot,
+			"status":  statusName(r.status),
+			"leader":  r.leader(),
+		},
+	}
+	for k, v := range extra {
+		event[k] = v
+	}
+	tlatrace.Emit(event)
+}
+
+func (c *Client) traceClientEvent(name string, cmdID CommandId, extra map[string]interface{}) {
+	event := map[string]interface{}{
+		"name":   name,
+		"module": "swift_client",
+		"cid":    strconv.FormatInt(int64(c.ClientId), 10),
+		"cmd":    commandIDMap(cmdID),
+		"state": map[string]interface{}{
+			"ballot": c.ballot,
+		},
+	}
+	for k, v := range extra {
+		event[k] = v
+	}
+	tlatrace.Emit(event)
+}
