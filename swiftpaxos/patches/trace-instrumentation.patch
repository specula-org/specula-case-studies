index 773f8f5..925bf39 100644
--- a/client/client.go
+++ b/client/client.go
@@ -20,6 +20,7 @@ import (
 	"github.com/imdea-software/swiftpaxos/replica/defs"
 	fastrpc "github.com/imdea-software/swiftpaxos/rpc"
 	"github.com/imdea-software/swiftpaxos/state"
+	"github.com/imdea-software/swiftpaxos/tlatrace"
 )
 
 type Client struct {
@@ -178,20 +179,53 @@ func (c *Client) SendProposal(cmd defs.Propose) {
 		d = c.ClosestId
 	}
 
+	event := map[string]interface{}{
+		"name":   "ClientSubmit",
+		"module": "client",
+		"cid":    strconv.FormatInt(int64(c.ClientId), 10),
+		"cmd": map[string]interface{}{
+			"client": cmd.ClientId,
+			"seq":    cmd.CommandId,
+			"op":     commandOpName(cmd.Command.Op),
+			"key":    int64(cmd.Command.K),
+		},
+		"leaderless": c.Leaderless,
+		"fast":       c.Fast,
+	}
+
 	if !c.Fast {
 		c.Println("sending command", cmd.CommandId, "to", d)
+		event["target"] = strconv.Itoa(d)
+		tlatrace.Emit(event)
 		c.writers[d].WriteByte(defs.PROPOSE)
 		cmd.Marshal(c.writers[d])
 		c.writers[d].Flush()
 	} else {
 		c.Println("sending command", cmd.CommandId, "to everyone")
+		targets := make([]string, 0, len(c.servers))
 		for rep := 0; rep < len(c.servers); rep++ {
 			if c.writers[rep] != nil {
+				targets = append(targets, strconv.Itoa(rep))
 				c.writers[rep].WriteByte(defs.PROPOSE)
 				cmd.Marshal(c.writers[rep])
 				c.writers[rep].Flush()
 			}
 		}
+		event["target"] = targets
+		tlatrace.Emit(event)
+	}
+}
+
+func commandOpName(op state.Operation) string {
+	switch op {
+	case state.PUT:
+		return "PUT"
+	case state.GET:
+		return "GET"
+	case state.SCAN:
+		return "SCAN"
+	default:
+		return "NONE"
 	}
 }
 
