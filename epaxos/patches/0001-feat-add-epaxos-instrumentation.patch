--- /dev/null
+++ b/epaxos/trace_helpers.go
@@ -0,0 +1,94 @@
+package epaxos
+
+import (
+	"strconv"
+
+	"github.com/imdea-software/swiftpaxos/state"
+	"github.com/imdea-software/swiftpaxos/tlatrace"
+)
+
+func statusName(status int8) string {
+	switch status {
+	case NONE:
+		return "NONE"
+	case PREACCEPTED:
+		return "PREACCEPTED"
+	case PREACCEPTED_EQ:
+		return "PREACCEPTED_EQ"
+	case ACCEPTED:
+		return "ACCEPTED"
+	case COMMITTED:
+		return "COMMITTED"
+	case EXECUTED:
+		return "EXECUTED"
+	default:
+		return "UNKNOWN"
+	}
+}
+
+func commandMap(cmd state.Command) map[string]interface{} {
+	op := "NONE"
+	switch cmd.Op {
+	case state.PUT:
+		op = "PUT"
+	case state.GET:
+		op = "GET"
+	case state.SCAN:
+		op = "SCAN"
+	}
+	return map[string]interface{}{
+		"op":  op,
+		"key": int64(cmd.K),
+	}
+}
+
+func commandsMap(cmds []state.Command) []map[string]interface{} {
+	out := make([]map[string]interface{}, 0, len(cmds))
+	for _, cmd := range cmds {
+		out = append(out, commandMap(cmd))
+	}
+	return out
+}
+
+func depsMap(deps []int32) []int32 {
+	if deps == nil {
+		return nil
+	}
+	out := make([]int32, len(deps))
+	copy(out, deps)
+	return out
+}
+
+func (r *Replica) traceEvent(name string, extra map[string]interface{}) {
+	event := map[string]interface{}{
+		"name":   name,
+		"module": "epaxos_replica",
+		"nid":    strconv.FormatInt(int64(r.Id), 10),
+	}
+	for k, v := range extra {
+		event[k] = v
+	}
+	tlatrace.Emit(event)
+}
+
+func (r *Replica) traceInstanceEvent(name string, replica, instance, ballot, seq int32, status int8, deps []int32, extra map[string]interface{}) {
+	event := map[string]interface{}{
+		"name":   name,
+		"module": "epaxos_replica",
+		"nid":    strconv.FormatInt(int64(r.Id), 10),
+		"iid": map[string]interface{}{
+			"replica":  replica,
+			"instance": instance,
+		},
+		"state": map[string]interface{}{
+			"ballot": ballot,
+			"status": statusName(status),
+			"seq":    seq,
+			"deps":   depsMap(deps),
+		},
+	}
+	for k, v := range extra {
+		event[k] = v
+	}
+	tlatrace.Emit(event)
+}
