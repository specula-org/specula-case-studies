@@ -12,6 +12,10 @@
 
 #include <rte_stdatomic.h>
 
+#ifdef DPDK_TLA_TRACE
+#include "rte_ring_tla_trace.h"
+#endif
+
 /**
  * @file rte_ring_hts_elem_pvt.h
  * It is not recommended to include this file directly,
@@ -216,8 +220,17 @@ __rte_ring_do_hts_enqueue_elem(struct rte_ring *r, const void *obj_table,
 	n =  __rte_ring_hts_move_prod_head(r, n, behavior, &head, &free);
 
 	if (n != 0) {
+#ifdef DPDK_TLA_TRACE
+		__tla_trace_reserve_prod(r, n);
+#endif
 		__rte_ring_enqueue_elems(r, head, obj_table, esize, n);
+#ifdef DPDK_TLA_TRACE
+		__tla_trace_write_data(r);
+#endif
 		__rte_ring_hts_update_tail(&r->hts_prod, head, n, 1);
+#ifdef DPDK_TLA_TRACE
+		__tla_trace_publish_tail(r);
+#endif
 	}
 
 	if (free_space != NULL)
@@ -257,8 +270,17 @@ __rte_ring_do_hts_dequeue_elem(struct rte_ring *r, void *obj_table,
 	n = __rte_ring_hts_move_cons_head(r, n, behavior, &head, &entries);
 
 	if (n != 0) {
+#ifdef DPDK_TLA_TRACE
+		__tla_trace_reserve_cons(r, n);
+#endif
 		__rte_ring_dequeue_elems(r, head, obj_table, esize, n);
+#ifdef DPDK_TLA_TRACE
+		__tla_trace_write_data(r);
+#endif
 		__rte_ring_hts_update_tail(&r->hts_cons, head, n, 0);
+#ifdef DPDK_TLA_TRACE
+		__tla_trace_publish_tail(r);
+#endif
 	}
 
 	if (available != NULL)
