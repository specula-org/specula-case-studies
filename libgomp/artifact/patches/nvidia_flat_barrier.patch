+		gomp_barrier_handle_tasks (gstate, bar, false);
+	      goto wait_on_this_thread;
+	    }
+	}
+      futex_waitv ((int *) &arr[i].cgen, tstate, (int *) &bar->generation,
+		   gstate);
+      goto wait_on_this_thread;
+
+    wait_on_next_thread:
+      continue;
+    }
+  gomp_assert_seenflags (bar, true);
