+		{
+		  if (__builtin_expect (threadgen & PRIMARY_WAITING_TG, 0))
+		    __atomic_fetch_and (&arr[i].cgen, ~PRIMARY_WAITING_TG,
+					MEMMODEL_RELAXED);
