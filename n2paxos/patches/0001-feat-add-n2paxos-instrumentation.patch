+-- Replicas --
+
+r1 127.0.0.1
+r2 127.0.0.1
+r3 127.0.0.1
+
+-- Clients --
+
+c1     127.0.0.1 
+
+-- Master --
+
+// alias -> address
+master 127.0.0.1
+
+masterPort: 7087
+
+
+protocol: n2paxos
+
+// Replicas
+noop:       false // do not execute
+thrifty:    false
+optread:    false
+leaderless: false
+fast:       false
+leader:     127.0.0.1 // if the port is not specified, port 7070 is used
+
+// Default port of any replica is 7070
+// This can be changed for all replicas:
+//     port: 7071
+// or for a specific replica:
+
+-- Apply to r1 --
+port: 7071
+-- Stop --
+-- Apply to r2 --
+port: 7072
+-- Stop --
+-- Apply to r3 --
+port: 7073
+-- Stop --
+
+// Clients
+reqs:        1000
+runTime:     1m // 5min
+writes:      100
+conflicts:   0 
+commandSize: 1000
+clones:      5 
+key:         42 // conflicting key
+
+pipeline: false
+pendings: 10000
+
+-- Apply to r2 --
+waitClosest: true
+
+-- Proxy --
+server_alias r1
+c1 (local)
+server_alias r2
+c1
+server_alias r3
+c1
+---
