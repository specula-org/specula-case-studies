diff --git a/n2paxos/trace_helpers.go b/n2paxos/trace_helpers.go
new file mode 100644
index 0000000..121cf9a
--- /dev/null
+++ b/n2paxos/trace_helpers.go
@@ -0,0 +1,90 @@
+package n2paxos
+
+import (
+	"strconv"
+
+	"github.com/imdea-software/swiftpaxos/state"
+	"github.com/imdea-software/swiftpaxos/tlatrace"
+)
+
+func phaseName(phase int) string {
+	switch phase {
+	case START:
+		return "START"
+	case COMMIT:
+		return "COMMIT"
+	default:
+		return "UNKNOWN"
+	}
+}
+
+func statusName(status int) string {
+	switch status {
+	case NORMAL:
+		return "NORMAL"
+	case RECOVERING:
+		return "RECOVERING"
+	default:
+		return "UNKNOWN"
+	}
+}
+
+func cmdIDMap(cmdID CommandId) map[string]interface{} {
+	return map[string]interface{}{
+		"client": cmdID.ClientId,
+		"seq":    cmdID.SeqNum,
+	}
+}
+
+func commandMap(cmd state.Command) map[string]interface{} {
+	op := "NONE"
+	switch cmd.Op {
+	case state.PUT:
+		op = "PUT"
+	case state.GET:
+		op = "GET"
+	case state.SCAN:
+		op = "SCAN"
+	}
+	return map[string]interface{}{
+		"op":  op,
+		"key": int64(cmd.K),
+	}
+}
+
+func (r *Replica) traceEvent(name string, extra map[string]interface{}) {
+	event := map[string]interface{}{
+		"name":   name,
+		"module": "n2paxos_replica",
+		"nid":    strconv.FormatInt(int64(r.Id), 10),
+		"state": map[string]interface{}{
+			"ballot":  r.ballot,
+			"cballot": r.cballot,
+			"status":  statusName(r.status),
+		},
+	}
+	for k, v := range extra {
+		event[k] = v
+	}
+	tlatrace.Emit(event)
+}
+
+func (r *Replica) traceSlotEvent(name string, slot int, cmdID CommandId, phase int, extra map[string]interface{}) {
+	event := map[string]interface{}{
+		"name":   name,
+		"module": "n2paxos_replica",
+		"nid":    strconv.FormatInt(int64(r.Id), 10),
+		"slot":   slot,
+		"cmd":    cmdIDMap(cmdID),
+		"state": map[string]interface{}{
+			"ballot":  r.ballot,
+			"cballot": r.cballot,
+			"status":  statusName(r.status),
+			"phase":   phaseName(phase),
+		},
+	}
+	for k, v := range extra {
+		event[k] = v
+	}
+	tlatrace.Emit(event)
+}
